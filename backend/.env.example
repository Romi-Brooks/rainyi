# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=rain_yi

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# JWT Configuration
JWT_SECRET=rain-yi-secret-key-change-in-production

# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Skills directory path (relative to backend/ or absolute)
SKILLS_DIR=../skills

# Redis Configuration (optional)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# MinIO Configuration (optional)
# MINIO_ENDPOINT=127.0.0.1:9000
# MINIO_ACCESS_KEY=admin
# MINIO_SECRET_KEY=your_secret_key
# MINIO_BUCKET=rain-yi
# MINIO_USE_SSL=false

# Emotion Summary (optional, requires DeepSeek API)
# ENABLE_EMOTION_SUMMARY=false
# EMOTION_SUMMARY_INTERVAL=10
